# TokioAI Configuration
# Copy this to ~/.tokioai/.env and fill in your values
# Or run: tokioai --setup

# ── Provider (choose one) ──
# TOKIOAI_PROVIDER=anthropic-vertex   # Claude via GCP Vertex AI
# TOKIOAI_PROVIDER=anthropic          # Claude via API key
# TOKIOAI_PROVIDER=openai             # OpenAI GPT
# TOKIOAI_PROVIDER=gemini             # Google Gemini (API key)
# TOKIOAI_PROVIDER=gemini-vertex      # Google Gemini via Vertex AI
# TOKIOAI_PROVIDER=openrouter         # OpenRouter (200+ models)
# TOKIOAI_PROVIDER=ollama             # Ollama (local, free)

# ── Model ──
# TOKIOAI_MODEL=opus                  # or sonnet, haiku, flash, gpt4o, llama, etc.

# ── Claude via Vertex AI ──
# VERTEX_PROJECT=your-gcp-project-id
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_REGION=global
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Claude via API key ──
# ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI ──
# OPENAI_API_KEY=sk-...

# ── Gemini (API key) ──
# GEMINI_API_KEY=AIza...

# ── Gemini via Vertex AI ──
# GEMINI_VERTEX_PROJECT=your-gcp-project-id
# GEMINI_SA_PATH=/path/to/gemini-service-account.json

# ── OpenRouter ──
# OPENROUTER_API_KEY=sk-or-...

# ── Ollama (local) ──
# OLLAMA_HOST=http://localhost:11434

# ── Optional: Remote hosts (SSH tools) ──
# RASPI_IP=192.168.1.100
# RASPI_SSH_USER=pi
# RASPI_TAILSCALE_IP=100.x.x.x
# SSH_KEY_RASPI=~/.ssh/id_rsa

# GCP_SSH_HOST=your-gcp-vm-ip
# GCP_SSH_USER=user
# SSH_KEY_GCP=~/.ssh/google_compute_engine

# ROUTER_IP=192.168.1.1

# ── Max tokens per response ──
# MAX_TOKENS=16384
